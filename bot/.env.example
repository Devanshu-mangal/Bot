# ==============================================================================
# Vera AI Challenge Bot - Environment Variables
# Copy this file to .env and fill in your values!
# ==============================================================================

# ==============================================================================
# LLM API Keys (Choose ONE or more - priority: Grok > Llama > Anthropic > OpenAI)
# ==============================================================================

# --- GROK API (Recommended) ---
# Get your key from https://x.ai
GROK_API_KEY=grok_Api_key
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-mini

# --- LLAMA API (Alternative) ---
# Use providers like Together.ai, Anyscale, Replicate, etc.
LLAMA_API_KEY=your_llama_api_key_here
LLAMA_BASE_URL=https://api.together.xyz/v1  # Example: Together.ai base URL
LLAMA_MODEL=meta-llama/Llama-3.1-70B-Versatile  # Example model

# --- ANTHROPIC API (Legacy) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OPENAI API (Legacy) ---
OPENAI_API_KEY=your_openai_api_key_here


# ==============================================================================
# Bot Configuration (Required)
# ==============================================================================
TEAM_NAME=Your Team Name
CONTACT_EMAIL=your-team-email@example.com
PORT=8080


# ==============================================================================
# Optional Configuration
# ==============================================================================
# DEBUG=true  # Uncomment for debug logging
